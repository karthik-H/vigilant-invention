  "component": [],
  "endpoint": [
    {
      "implementation_id": "main_include_task_router",
      "test_cases": [
        {
          "description": "Verify that a new task is successfully created when valid data is posted to /tasks.",
          "id": "TC01_create_task_valid",
          "implementation_id": "main_include_task_router",
          "name": "Create Task with Valid Data",
          "request_body_json": {
            "description": "Milk, eggs, bread",
            "priority": 2,
            "title": "Buy groceries"
          },
          "request_headers": {
            "Content-Type": "application/json"
          },
          "request_method": "POST",
          "request_url": "/tasks",
          "response_body_json": {
            "description": "Milk, eggs, bread",
            "id": 1,
            "priority": 2,
            "status": "pending",
            "title": "Buy groceries"
          },
          "response_status_code": 201,
          "test_setup": {
            "given": "No existing tasks.",
            "then": "Task is created and returned with status 201.",
            "when": "POST valid task data to /tasks."
          },
          "type": "positive"
        },
        {
          "description": "Ensure that task creation fails if the required 'title' field is missing.",
          "id": "TC02_create_task_missing_title",
          "implementation_id": "main_include_task_router",
          "name": "Create Task with Missing Title",
          "request_body_json": {
            "description": "Read chapter 1",
            "priority": 1
          },
          "request_headers": {
            "Content-Type": "application/json"
          },
          "request_method": "POST",
          "request_url": "/tasks",
          "response_body_json": {
            "detail": [
              {
                "loc": [
                  "body",
                  "title"
                ],
                "msg": "field required",
                "type": "value_error.missing"
              }
            ]
          },
          "response_status_code": 422,
          "test_setup": {
            "given": "No existing tasks.",
            "then": "Validation error for missing title.",
            "when": "POST task data without 'title'."
          },
          "type": "negative"
        },
        {
          "description": "Verify that task creation fails when 'title' is an empty string.",
          "id": "TC03_create_task_empty_title",
          "implementation_id": "main_include_task_router",
          "name": "Create Task with Empty Title",
          "request_body_json": {
            "description": "Should fail due to empty title",
            "priority": 1,
            "title": ""
          },
          "request_headers": {
            "Content-Type": "application/json"
          },
          "request_method": "POST",
          "request_url": "/tasks",
          "response_body_json": {
            "detail": [
              {
                "loc": [
                  "body",
                  "title"
                ],
                "msg": "Title must not be empty",
                "type": "value_error"
              }
            ]
          },
          "response_status_code": 422,
          "test_setup": {
            "given": "No existing tasks.",
            "then": "Validation error for empty title.",
            "when": "POST task with empty title."
          },
          "type": "edge"
        },
        {
          "description": "Verify that task creation fails when 'priority' is a negative number.",
          "id": "TC04_create_task_invalid_priority",
          "implementation_id": "main_include_task_router",
          "name": "Create Task with Invalid Priority",
          "request_body_json": {
            "description": "Weekly call",
            "priority": -1,
            "title": "Call mom"
          },
          "request_headers": {
            "Content-Type": "application/json"
          },
          "request_method": "POST",
          "request_url": "/tasks",
          "response_body_json": {
            "detail": [
              {
                "loc": [
                  "body",
                  "priority"
                ],
                "msg": "Priority must be >= 0",
                "type": "value_error"
              }
            ]
          },
          "response_status_code": 422,
          "test_setup": {
            "given": "No existing tasks.",
            "then": "Validation error for invalid priority.",
            "when": "POST task with negative priority."
          },
          "type": "negative"
        },
        {
          "description": "Check system behavior when task title is at maximum allowed length (e.g., 255 chars).",
          "id": "TC05_create_task_long_title",
          "implementation_id": "main_include_task_router",
          "name": "Create Task with Extremely Long Title",
          "request_body_json": {
            "description": "Edge case test",
            "priority": 3,
            "title": "T.repeat(255)"
          },
          "request_headers": {
            "Content-Type": "application/json"
          },
          "request_method": "POST",
          "request_url": "/tasks",
          "response_body_json": {
            "description": "Edge case test",
            "id": 2,
            "priority": 3,
            "status": "pending",
            "title": "T.repeat(255)"
          },
          "response_status_code": 201,
          "test_setup": {
            "given": "No existing tasks.",
            "then": "Task is created successfully.",
            "when": "POST task with a 255 character title."
          },
          "type": "edge"
        },
        {
          "description": "Verify that task creation fails when title exceeds maximum length (e.g., 256 chars).",
          "id": "TC06_create_task_overlong_title",
          "implementation_id": "main_include_task_router",
          "name": "Create Task with Overly Long Title",
          "request_body_json": {
            "description": "Should fail due to title length",
            "priority": 3,
            "title": "T.repeat(256)"
          },
          "request_headers": {
            "Content-Type": "application/json"
          },
          "request_method": "POST",
          "request_url": "/tasks",
          "response_body_json": {
            "detail": [
              {
                "loc": [
                  "body",
                  "title"
