{
  "function": [
    {
      "implementation_id": "task_service_create_task_function",
      "test_cases": [
        {
          "description": "Verify that a task is created successfully when all required fields are provided and valid.",
          "id": "tc_create_task_valid_data",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_with_valid_data",
          "test_setup": {
            "given": {
              "task_data": {
                "description": "Milk, Bread, Cheese",
                "due_date": "2024-07-01",
                "priority": "medium",
                "title": "Buy groceries"
              },
              "user_name": "alice"
            },
            "then": {
              "created_task": {
                "created_by": "alice",
                "description": "Milk, Bread, Cheese",
                "due_date": "2024-07-01",
                "id": "generated_id",
                "priority": "medium",
                "title": "Buy groceries"
              }
            },
            "when": "TaskService.create_task is called with valid task_data and user_name"
          },
          "type": "positive"
        },
        {
          "description": "Verify that creating a task fails when the required 'title' field is missing.",
          "id": "tc_create_task_missing_title",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_missing_title",
          "test_setup": {
            "given": {
              "task_data": {
                "description": "Call the doctor",
                "due_date": "2024-07-05",
                "priority": "high"
              },
              "user_name": "bob"
            },
            "then": {
              "exception": {
                "message": "Title is required",
                "name": "ValueError"
              }
            },
            "when": "TaskService.create_task is called with missing 'title' in task_data"
          },
          "type": "negative"
        },
        {
          "description": "Verify that creating a task with an empty title fails validation.",
          "id": "tc_create_task_empty_title",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_empty_title",
          "test_setup": {
            "given": {
              "task_data": {
                "description": "Finish project",
                "due_date": "2024-07-03",
                "priority": "low",
                "title": ""
              },
              "user_name": "carol"
            },
            "then": {
              "exception": {
                "message": "Title is required",
                "name": "ValueError"
              }
            },
            "when": "TaskService.create_task is called with empty string as 'title'"
          },
          "type": "negative"
        },
        {
          "description": "Verify that a task is created successfully when 'description' is null or not provided.",
          "id": "tc_create_task_null_description",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_null_description",
          "test_setup": {
            "given": {
              "task_data": {
                "description": null,
                "due_date": "2024-07-02",
                "priority": "medium",
                "title": "Take out trash"
              },
              "user_name": "dave"
            },
            "then": {
              "created_task": {
                "created_by": "dave",
                "description": null,
                "due_date": "2024-07-02",
                "id": "generated_id",
                "priority": "medium",
                "title": "Take out trash"
              }
            },
            "when": "TaskService.create_task is called with null 'description'"
          },
          "type": "edge"
        },
        {
          "description": "Verify that the system accepts a task with a title at the maximum allowed length.",
          "id": "tc_create_task_long_title",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_with_long_title",
          "test_setup": {
            "given": {
              "task_data": {
                "description": "A very long title",
                "due_date": "2024-07-10",
                "priority": "low",
                "title": "T.repeat(255)"
              },
              "user_name": "eve"
            },
            "then": {
              "created_task": {
                "created_by": "eve",
                "description": "A very long title",
                "due_date": "2024-07-10",
                "id": "generated_id",
                "priority": "low",
                "title": "T.repeat(255)"
              }
            },
            "when": "TaskService.create_task is called with title of maximum length"
          },
          "type": "edge"
        },
        {
          "description": "Verify that the function returns an error if due_date format is invalid.",
          "id": "tc_create_task_invalid_due_date_format",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_invalid_due_date_format",
          "test_setup": {
            "given": {
              "task_data": {
                "description": "Submit by end of month",
                "due_date": "31-07-2024",
                "priority": "high",
                "title": "File taxes"
              },
              "user_name": "frank"
            },
            "then": {
              "exception": {
                "message": "Invalid date format",
                "name": "ValueError"
              }
            },
            "when": "TaskService.create_task is called with an incorrectly formatted 'due_date'"
          },
          "type": "negative"
        },
        {
          "description": "Verify that the function returns an error if user_name is missing.",
          "id": "tc_create_task_missing_user_name",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_missing_user_name",
          "test_setup": {
            "given": {
              "task_data": {
                "description": "Complete chapter 4",
                "due_date": "2024-07-15",
                "priority": "low",
                "title": "Read book"
              },
              "user_name": null
            },
            "then": {
              "exception": {
                "message": "User name is required",
                "name": "ValueError"
              }
            },
            "when": "TaskService.create_task is called with null user_name"
          },
          "type": "negative"
        },
        {
          "description": "Verify that the function handles a repository failure gracefully and returns an appropriate error.",
          "id": "tc_create_task_repository_failure",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_repository_failure",
          "test_setup": {
            "given": {
              "repository_behavior": "add_task_raises_exception",
              "task_data": {
                "description": "Discuss Q3 targets",
                "due_date": "2024-07-12",
                "priority": "medium",
                "title": "Schedule meeting"
              },
              "user_name": "george"
            },
            "then": {
              "exception": {
                "message": "Failed to persist task",
                "name": "RepositoryException"
              }
            },
            "when": "TaskService.create_task is called and repository.add_task raises an Exception"
          },
          "type": "negative"
        },
        {
          "description": "Verify that a task is created successfully with only the required fields.",
          "id": "tc_create_task_minimal_data",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_with_minimal_required_data",
          "test_setup": {
            "given": {
              "task_data": {
                "title": "Check email"
              },
              "user_name": "hannah"
            },
            "then": {
              "created_task": {
                "created_by": "hannah",
                "description": null,
                "due_date": null,
                "id": "generated_id",
                "priority": null,
                "title": "Check email"
              }
            },
            "when": "TaskService.create_task is called with only the 'title' field"
          },
          "type": "edge"
        },
        {
          "description": "Verify that creating a task with a duplicate title is handled according to business rules.",
          "id": "tc_create_task_duplicate_title",
          "implementation_id": "task_service_create_task_function",
          "name": "test_create_task_with_duplicate_title",
          "test_setup": {
            "given": {
              "precondition": "A task with title 'Morning standup' already exists for user 'ivan'",
              "task_data": {
                "description": "Daily team meeting",
                "due_date": "2024-07-10",
                "priority": "medium",
                "title": "Morning standup"
              },
              "user_name": "ivan"
            },
            "then": {
              "created_task": {
                "created_by": "ivan",
                "description": "Daily team meeting",
                "due_date": "2024-07-10",
                "id": "new_generated_id",
                "priority": "medium",
                "title": "Morning standup"
              }
            },
            "when": "TaskService.create_task is called with a duplicate title"
          },
          "type": "edge"
        }
      ]
    },
    {
      "implementation_id": "task_repository_add_task_function",
      "test_cases": [
        {
          "description": "Tests adding a task with valid title and description.",
          "id": "add_task_valid_input",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task with Valid Input",
          "test_setup": {
            "given": {
              "description": "Milk, Bread, Eggs",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": "Buy groceries"
            },
            "then": {
              "created_task": {
                "description": "Milk, Bread, Eggs",
                "id": 1,
                "title": "Buy groceries"
              },
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": "Milk, Bread, Eggs",
                  "id": 1,
                  "title": "Buy groceries"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: Buy groceries"
            },
            "when": "TaskRepository.add_task is called with valid title and description."
          },
          "type": "positive"
        },
        {
          "description": "Tests adding a task with an empty title field.",
          "id": "add_task_empty_title",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task with Empty Title",
          "test_setup": {
            "given": {
              "description": "Some description",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": ""
            },
            "then": {
              "created_task": null,
              "error": "Title cannot be empty",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_saved": false
            },
            "when": "TaskRepository.add_task is called with an empty title."
          },
          "type": "negative"
        },
        {
          "description": "Tests adding a task when the description is missing (null or not provided).",
          "id": "add_task_missing_description",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task with Missing Description",
          "test_setup": {
            "given": {
              "description": null,
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": "Write report"
            },
            "then": {
              "created_task": {
                "description": null,
                "id": 1,
                "title": "Write report"
              },
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": null,
                  "id": 1,
                  "title": "Write report"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: Write report"
            },
            "when": "TaskRepository.add_task is called with title and missing description."
          },
          "type": "edge"
        },
        {
          "description": "Tests adding a task with maximum length title and description.",
          "id": "add_task_long_title_description",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task with Long Title and Description",
          "test_setup": {
            "given": {
              "description": "D.repeat(1024)",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": "T.repeat(255)"
            },
            "then": {
              "created_task": {
                "description": "D.repeat(1024)",
                "id": 1,
                "title": "T.repeat(255)"
              },
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": "D.repeat(1024)",
                  "id": 1,
                  "title": "T.repeat(255)"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: T.repeat(255)"
            },
            "when": "TaskRepository.add_task is called with long title and description."
          },
          "type": "edge"
        },
        {
          "description": "Tests adding a task with identical title and description to an existing task.",
          "id": "add_task_duplicate_task",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Duplicate Task",
          "test_setup": {
            "given": {
              "description": "Chapter 1",
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": "Chapter 1",
                  "id": 1,
                  "title": "Read book"
                }
              ],
              "json_file_exists": true,
              "title": "Read book"
            },
            "then": {
              "created_task": {
                "description": "Chapter 1",
                "id": 2,
                "title": "Read book"
              },
              "id_counter": 3,
              "internal_task_list": [
                {
                  "description": "Chapter 1",
                  "id": 1,
                  "title": "Read book"
                },
                {
                  "description": "Chapter 1",
                  "id": 2,
                  "title": "Read book"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: Read book"
            },
            "when": "TaskRepository.add_task is called with duplicate task data."
          },
          "type": "edge"
        },
        {
          "description": "Tests adding a task when the JSON file does not exist (should create file).",
          "id": "add_task_no_json_file",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task When JSON File Does Not Exist",
          "test_setup": {
            "given": {
              "description": "Create file test",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": false,
              "title": "New Task"
            },
            "then": {
              "created_task": {
                "description": "Create file test",
                "id": 1,
                "title": "New Task"
              },
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": "Create file test",
                  "id": 1,
                  "title": "New Task"
                }
              ],
              "json_file_created": true,
              "json_file_saved": true,
              "log_entry": "Task created: New Task"
            },
            "when": "TaskRepository.add_task is called and JSON file is absent."
          },
          "type": "edge"
        },
        {
          "description": "Tests adding a task when the JSON file is corrupted (write should succeed, old data lost).",
          "id": "add_task_invalid_json_file",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task When JSON File Is Corrupted",
          "test_setup": {
            "given": {
              "description": "Corrupted file test",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_corrupted": true,
              "json_file_exists": true,
              "title": "Fix bug"
            },
            "then": {
              "created_task": {
                "description": "Corrupted file test",
                "id": 1,
                "title": "Fix bug"
              },
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": "Corrupted file test",
                  "id": 1,
                  "title": "Fix bug"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: Fix bug",
              "warning": "Old data could not be loaded due to corruption"
            },
            "when": "TaskRepository.add_task is called and JSON file is corrupted."
          },
          "type": "negative"
        },
        {
          "description": "Tests adding a task when the ID counter is at maximum value for integer.",
          "id": "add_task_id_overflow",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task When ID Counter Is Near Overflow",
          "test_setup": {
            "given": {
              "description": "Testing ID counter overflow",
              "id_counter": 2147483647,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": "Overflow test"
            },
            "then": {
              "created_task": {
                "description": "Testing ID counter overflow",
                "id": 2147483647,
                "title": "Overflow test"
              },
              "id_counter": 2147483648,
              "internal_task_list": [
                {
                  "description": "Testing ID counter overflow",
                  "id": 2147483647,
                  "title": "Overflow test"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: Overflow test"
            },
            "when": "TaskRepository.add_task is called when ID is at max int."
          },
          "type": "edge"
        },
        {
          "description": "Tests adding a task with special characters in title and description.",
          "id": "add_task_special_characters",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task with Special Characters",
          "test_setup": {
            "given": {
              "description": "Newline:\nUnicode: \u001f600",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": "!@#$%^&*()_+-=[]{}|;':\",.<>/?"
            },
            "then": {
              "created_task": {
                "description": "Newline:\nUnicode: \u001f600",
                "id": 1,
                "title": "!@#$%^&*()_+-=[]{}|;':\",.<>/?"
              },
              "id_counter": 2,
              "internal_task_list": [
                {
                  "description": "Newline:\nUnicode: \u001f600",
                  "id": 1,
                  "title": "!@#$%^&*()_+-=[]{}|;':\",.<>/?"
                }
              ],
              "json_file_saved": true,
              "log_entry": "Task created: !@#$%^&*()_+-=[]{}|;':\",.<>/?"
            },
            "when": "TaskRepository.add_task is called with special characters."
          },
          "type": "edge"
        },
        {
          "description": "Tests adding a task with incorrect types (e.g., title as integer).",
          "id": "add_task_invalid_types",
          "implementation_id": "task_repository_add_task_function",
          "name": "Add Task with Invalid Types",
          "test_setup": {
            "given": {
              "description": [
                "not",
                "a",
                "string"
              ],
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_exists": true,
              "title": 12345
            },
            "then": {
              "created_task": null,
              "error": "Invalid data types: title and description must be strings",
              "id_counter": 1,
              "internal_task_list": [],
              "json_file_saved": false
            },
            "when": "TaskRepository.add_task is called with invalid types."
          },
          "type": "negative"
        }
      ]
    }
